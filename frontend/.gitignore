# ========================
# DOSSIERS LOURDS (Ne jamais envoyer)
# ========================
node_modules/
/node_modules
frontend/node_modules/
backend/node_modules/

# ========================
# FICHIERS DE SÉCURITÉ (Mots de passe, clés API)
# ========================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ========================
# FICHIERS DE BUILD (Générés automatiquement par React/Vite)
# ========================
dist/
build/
dist-ssr/
*.local

# ========================
# FICHIERS SYSTÈME (Générés par Windows ou Mac)
# ========================
.DS_Store
Thumbs.db
desktop.ini

# ========================
# LOGS (Historiques d'erreurs)
# ========================
npm-debug.log*
yarn-debug.log*
yarn-error.log*